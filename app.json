{
  "expo": {
    "name": "Capitec",
    "slug": "capitecbank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "capitecbank",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mickytroxxy.capitecbank"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.mickytroxxy.capitecbank"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Capitec needs access to your Camera to enable scanning and uploading of documents efficiently. By allowing camera access, you can easily digitize and share your documents through the app.",
          "enableMicrophonePermission": true,
          "enableCodeScanner": true,
          "microphonePermissionText": "Capitec needs access to your Microphone to enable voice commands or audio notes for document handling and collaboration."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Capitec requires access to your microphone for real-time AI assistant voice calls."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "471a5300-7ce4-478b-91c3-7ec6af6a6b0b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "deslinemayog",
    "updates": {
      "url": "https://u.expo.dev/471a5300-7ce4-478b-91c3-7ec6af6a6b0b"
    }
  }
}
